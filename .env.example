# Postgres connection string (Neon, Supabase, or Vercel Postgres — see doc §3.2/§3.3)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js v5 JWT signing secret, gates /admin — generate with `npx auth secret`
AUTH_SECRET=

# Vercel Blob read/write token — custom-order reference photo uploads
BLOB_READ_WRITE_TOKEN=

# Resend API key — confirmation emails for custom-order/contact submissions.
# Get one at resend.com. Without a verified sending domain, Resend only
# delivers to the email address on the Resend account itself, not to
# arbitrary customers — verify a domain once one exists (see update.md).
RESEND_API_KEY=

# Studio owner's inbox — gets a copy of every new custom-order/contact submission
STUDIO_NOTIFY_EMAIL=

# Xendit (cart/checkout payments — Stripe isn't available for PH accounts;
# switched from PayMongo to Xendit for broader international card acceptance).
# Get keys at dashboard.xendit.co/settings/developers#api-keys. Test and live
# keys are separate — use the TEST secret key here and in .env.local for local
# dev; only put the LIVE key in Vercel's Production environment once actually
# ready to take real payments. No public/publishable key is needed — Payment
# Session creation is entirely server-side.
XENDIT_SECRET_KEY=

# Static verification token Xendit sends back on every webhook request
# (x-callback-token header) — get this after registering the webhook endpoint
# at dashboard.xendit.co/settings/developers#callbacks
XENDIT_WEBHOOK_TOKEN=
